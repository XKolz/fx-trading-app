# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fx_trading

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Mail (Gmail SMTP example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=FX Trading App <your_email@gmail.com>

# FX Rate API (https://www.exchangerate-api.com - free tier)
FX_API_KEY=your_exchangerate_api_key
FX_API_BASE_URL=https://v6.exchangerate-api.com/v6

# Cache TTL in seconds (default: 300 = 5 minutes)
FX_CACHE_TTL=300

# App
PORT=3000
NODE_ENV=development
